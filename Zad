struct Employee {
    int id;
    double payPerHour;
    double hours;
};

double calculateSalary(double payPerHour, double hours) {
    double salary;

    if (hours <= 40) {
        salary = payPerHour * hours;
    } else {
        salary = 40 * payPerHour + (hours - 40) * payPerHour * 1.5;
    }

    salary = salary - salary * 0.0365;

    return salary;
}

void addEmployee() {
    FILE *file;
    struct Employee emp, temp;
    int count = 0;

    file = fopen("employees.dat", "ab+");
    if (file == NULL) {
        printf("Error opening file.\n");
        return;
    }

    rewind(file);

    while (fread(&temp, sizeof(struct Employee), 1, file) == 1) {
        count++;
    }

    if (count >= 30) {
        printf("Maximum number of employees reached.\n");
        fclose(file);
        return;
    }

    printf("Enter employee id: ");
    scanf("%d", &emp.id);

    printf("Enter pay per hour: ");
    scanf("%lf", &emp.payPerHour);

    printf("Enter worked hours: ");
    scanf("%lf", &emp.hours);

    fwrite(&emp, sizeof(struct Employee), 1, file);

    fclose(file);
    printf("Employee added successfully.\n");
}

void showSalaries() {
    FILE *file;
    struct Employee emp;
    double salary;

    file = fopen("employees.dat", "rb");
    if (file == NULL) {
        printf("File not found.\n");
        return;
    }

    while (fread(&emp, sizeof(struct Employee), 1, file) == 1) {
        salary = calculateSalary(emp.payPerHour, emp.hours);
        printf("Employee ID: %d, Weekly salary: %.2lf\n", emp.id, salary);
    }

    fclose(file);
}
